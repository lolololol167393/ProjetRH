<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Gestion RH{% endblock %}</title>
        
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" href="">WorkTogether</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_user_index') }}">Agents</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_type_conges_index') }}">Congés</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_role_index') }}">Rôles</a></li>
                    </ul>
                    <div class="navbar-nav ms-auto">
                        {% if app.user %}
                            <span class="nav-link text-light">Bonjour, {{ app.user.userIdentifier }}</span>
                            <a class="nav-link btn btn-outline-danger btn-sm" href="{{ path('app_logout') }}">Déconnexion</a>
                        {% else %}
                            <a class="nav-link btn btn-outline-primary btn-sm" href="{{ path('app_login') }}">Connexion</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        <div class="container">
            {% block body %}{% endblock %}
        </div>
    </body>
</html>
